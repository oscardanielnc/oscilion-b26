# Oscilion — plantilla de entorno.
# En la VM Oracle: copiar a /etc/oscilion.env (root:root, chmod 600).
# NUNCA subir el .env real al repo.

# Modo: dry-run (seguro, no opera) | paper | live
OSCILION_MODE=dry-run
OSCILION_VERSION=0.6.0-pilot

# Universo / timeframes (el núcleo lo define oscilion/strategies/assignment.py)
OSCILION_SYMBOLS=BTC/USDT:USDT,BNB/USDT:USDT,TRX/USDT:USDT,LINK/USDT:USDT,DOT/USDT:USDT
OSCILION_BASE_TF=1h
OSCILION_FAST_TF=15m
OSCILION_EXCHANGE=binanceusdm

# Loop (en vivo: 5 min basta; las señales son de 1h/4h)
OSCILION_TICK_SECONDS=300

# Riesgo (INVARIANTES — ver docs/RISK_MODEL.md)
OSCILION_RISK_PER_TRADE=0.02
OSCILION_MIN_PROFIT=0.05
OSCILION_MIN_RR=2.5

# Validación forward: inicio del período "no visto". setup_vm.sh lo fija a la
# fecha de despliegue. Manual: epoch ms (p.ej. `date +%s`*1000).
# OSCILION_FORWARD_INCEPTION_MS=

# Alertas push (ntfy.sh — abrir la app ntfy y suscribirse a este canal)
OSCILION_NTFY_TOPIC=oscar-oscilion-b26

# API / dashboard. 0.0.0.0 = accesible por IP pública (como kepler). Requiere abrir
# el puerto en firewalld Y en la Security List de Oracle Cloud. Es solo lectura
# (dry-run, sin órdenes); aun así considera auth/SSH-tunnel si quieres privacidad.
OSCILION_API_HOST=0.0.0.0
OSCILION_API_PORT=8787

OSCILION_LOG_LEVEL=INFO

# Credenciales de exchange (Fase live — dejar vacías en dry-run)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
