# Oscilion — plantilla de entorno.
# En la VM Oracle: copiar a /etc/oscilion.env (root:root, chmod 600).
# NUNCA subir el .env real al repo.

# Modo: dry-run (seguro, no opera) | paper | live
OSCILION_MODE=dry-run
OSCILION_VERSION=0.1.0-phase1

# Universo y timeframes
OSCILION_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT
OSCILION_BASE_TF=1h
OSCILION_FAST_TF=15m
OSCILION_EXCHANGE=binanceusdm

# Loop
OSCILION_TICK_SECONDS=60

# Riesgo (INVARIANTES — ver docs/RISK_MODEL.md)
OSCILION_RISK_PER_TRADE=0.02
OSCILION_MIN_PROFIT=0.05
OSCILION_MIN_RR=2.5
OSCILION_TAKER_FEE=0.00036
OSCILION_MAX_CONCURRENT=3

# Circuit breaker
OSCILION_MAX_DAILY_LOSS=0.06
OSCILION_MAX_ERRORS=10

# API
OSCILION_API_HOST=127.0.0.1
OSCILION_API_PORT=8787

OSCILION_LOG_LEVEL=INFO

# Credenciales de exchange (Fase 8 — dejar vacías hasta entonces)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Alertas Telegram (opcional)
# OSCILION_TG_TOKEN=
# OSCILION_TG_CHAT=
